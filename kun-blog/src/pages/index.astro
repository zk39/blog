---
import Base from '../layouts/Base.astro';
import Search from '../components/Search.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const postsEn = await getCollection('posts-en');
const enMap = new Map(postsEn.map(p => [p.id, p]));

const allTags = [...new Set(posts.flatMap(p => p.data.tags))];
const tagCounts = allTags.map(tag => ({
  name: tag,
  count: posts.filter(p => p.data.tags.includes(tag)).length,
}));

function formatDate(date: Date) {
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${date.getFullYear()} ${months[date.getMonth()]} ${date.getDate()}`;
}
---
<Base>
  <section class="hero">
    <div class="hero-content">
      <h1>
        <span class="lang-zh">你好，我是张堃</span>
        <span class="lang-en">Hey, I'm Kun Zhang</span>
      </h1>
      <p class="lang-zh">软件工程师，喜欢折腾 Web、研究系统设计，偶尔写写生活感悟。</p>
      <p class="lang-en">Software engineer & creative thinker. Writing about web development, design patterns, and the occasional life reflection.</p>
    </div>
  </section>

  <Search />

  <section class="tags-section">
    <div class="tags-row">
      <button class="tag active" data-tag="all">
        <span class="lang-zh">全部</span>
        <span class="lang-en">All</span>
      </button>
      {tagCounts.map(({ name, count }) => (
        <button class="tag" data-tag={name}>{name}<span class="count">{count}</span></button>
      ))}
    </div>
  </section>

  <section class="posts-section">
    <div class="posts-list">
      {posts.map((post) => {
        const enPost = enMap.get(post.id);
        const slug = post.id.replace(/\.md$/, '');
        const zhSearch = `${post.data.title} ${post.data.description} ${post.data.tags.join(' ')}`.toLowerCase();
        const enSearch = enPost
          ? `${enPost.data.title} ${enPost.data.description} ${enPost.data.tags.join(' ')}`.toLowerCase()
          : zhSearch;
        return (
          <a
            class="post-item"
            href={`/posts/${slug}`}
            data-tags={post.data.tags.join(',')}
            data-search-zh={zhSearch}
            data-search-en={enSearch}
          >
            <span class="post-date">{formatDate(post.data.date)}</span>
            <div class="post-content">
              <div class="post-title">
                <span class="lang-zh">{post.data.title}</span>
                <span class="lang-en">{enPost ? enPost.data.title : post.data.title}</span>
              </div>
              <div class="post-desc">
                <span class="lang-zh">{post.data.description}</span>
                <span class="lang-en">{enPost ? enPost.data.description : post.data.description}</span>
              </div>
              <div class="post-tags">
                {post.data.tags.map((tag: string) => (
                  <span class="post-tag lang-zh">{tag}</span>
                ))}
                {(enPost ?? post).data.tags.map((tag: string) => (
                  <span class="post-tag lang-en">{tag}</span>
                ))}
              </div>
            </div>
            <span class="post-arrow">→</span>
          </a>
        );
      })}
    </div>
    <div id="no-results" style="display:none;text-align:center;padding:64px 24px;color:var(--text-muted);">
      <p class="lang-zh">没有找到匹配的文章</p>
      <p class="lang-en">No matching posts found</p>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding: 80px max(24px, calc((100vw - var(--max-width)) / 2)) 48px;
    position: relative;
  }

  .hero::after {
    content: '';
    position: absolute;
    top: 0;
    right: 10%;
    width: 280px;
    height: 280px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 8%, transparent), transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .hero-content { position: relative; z-index: 1; }

  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
  }

  .hero p {
    font-size: 1.15rem;
    color: var(--text-secondary);
    max-width: 520px;
    line-height: 1.7;
  }

  .tags-section {
    padding: 16px max(24px, calc((100vw - var(--max-width)) / 2)) 8px;
  }

  .tags-row { display: flex; flex-wrap: wrap; gap: 8px; }

  .tag {
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 0.82rem;
    font-weight: 550;
    background: var(--tag-bg);
    color: var(--tag-text);
    cursor: pointer;
    border: none;
    transition: all var(--transition);
    user-select: none;
    font-family: var(--font-body);
  }

  .tag:hover { background: var(--border); color: var(--text-primary); }
  .tag.active { background: var(--tag-active-bg); color: var(--tag-active-text); }
  .tag .count { font-size: 0.72rem; opacity: 0.65; margin-left: 4px; font-weight: 400; }

  .posts-section {
    padding: 16px max(24px, calc((100vw - var(--max-width)) / 2)) 80px;
  }

  .posts-list { display: flex; flex-direction: column; gap: 2px; }

  .post-item {
    display: flex;
    align-items: baseline;
    gap: 16px;
    padding: 18px 16px;
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition);
  }

  .post-item:hover {
    background: var(--bg-card);
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
    white-space: nowrap;
    min-width: 90px;
    flex-shrink: 0;
  }

  .post-content { flex: 1; min-width: 0; }

  .post-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.08rem;
    line-height: 1.4;
    margin-bottom: 4px;
  }

  .post-desc {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-tags { display: flex; gap: 6px; margin-top: 8px; }

  .post-tag {
    font-size: 0.72rem;
    padding: 2px 10px;
    border-radius: 12px;
    background: var(--tag-bg);
    color: var(--tag-text);
    font-weight: 500;
  }

  .post-arrow {
    color: var(--text-muted);
    font-size: 1.1rem;
    opacity: 0;
    transform: translateX(-4px);
    transition: all var(--transition);
    flex-shrink: 0;
  }

  .post-item:hover .post-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .post-item { flex-direction: column; gap: 4px; padding: 14px 12px; }
    .post-date { font-size: 0.72rem; }
  }
</style>

<script>
  // ── Tag filter ────────────────────────────────────────
  document.querySelectorAll('.tag').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tag').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
      const tag = (btn as HTMLElement).dataset.tag;
      filterPosts(tag, getCurrentSearch());
    });
  });

  // ── Search (lang-aware) ───────────────────────────────
  function getCurrentSearch(): string {
    return (document.querySelector('.search-input') as HTMLInputElement)?.value?.toLowerCase() ?? '';
  }

  function getCurrentLang(): string {
    return document.documentElement.getAttribute('data-lang') || 'zh';
  }

  function filterPosts(tag: string | undefined, query: string) {
    const lang = getCurrentLang();
    let visible = 0;
    document.querySelectorAll('.post-item').forEach(el => {
      const item = el as HTMLElement;
      const postTags = item.dataset.tags || '';
      const search = lang === 'en' ? (item.dataset.searchEn || '') : (item.dataset.searchZh || '');
      const tagMatch = !tag || tag === 'all' || postTags.split(',').includes(tag);
      const searchMatch = !query || search.includes(query);
      const show = tagMatch && searchMatch;
      item.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    const noResults = document.getElementById('no-results');
    if (noResults) noResults.style.display = visible === 0 ? '' : 'none';
  }

  // Re-run filter when language switches so search stays accurate
  const html = document.documentElement;
  const observer = new MutationObserver(() => {
    const activeTag = (document.querySelector('.tag.active') as HTMLElement)?.dataset.tag;
    filterPosts(activeTag, getCurrentSearch());
  });
  observer.observe(html, { attributes: true, attributeFilter: ['data-lang'] });
</script>
