---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('emba');
  return entries.map(entry => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { course_code, course_name, title, description, date, learning_outcome, status, category } = entry.data;

const dateFormatted = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});

const categoryLabel = category === 'core' ? 'BUS Core Course' : 'IT Concentration';
const categoryColor = category === 'core' ? 'var(--accent)' : '#10b981';
---

<Base title={`${course_code} – ${title}`} description={description}>
  <article class="essay-view">

    <div class="essay-nav">
      <a href="/emba" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        EMBA Portfolio
      </a>
    </div>

    <header class="essay-header">
      <div class="meta-row">
        <span class="course-badge" style={`color: ${categoryColor}; background: color-mix(in srgb, ${categoryColor} 12%, transparent)`}>
          {course_code}
        </span>
        <span class="category-tag">{categoryLabel}</span>
        <span class={`status-tag ${status === 'complete' ? 'tag-done' : 'tag-draft'}`}>
          {status === 'complete' ? '✓ Complete' : 'Draft'}
        </span>
      </div>

      <h1 class="essay-title">{title}</h1>
      <p class="course-name-full">{course_name}</p>
      <p class="essay-desc">{description}</p>

      <div class="outcome-box">
        <div class="outcome-header">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          MBA Learning Outcome
        </div>
        <p class="outcome-text">{learning_outcome}</p>
      </div>

      <time class="essay-date">{dateFormatted}</time>
    </header>

    <div class="essay-body">
      <Content />
    </div>

  </article>
</Base>

<style>
  .essay-view {
    padding: 48px max(24px, calc((100vw - var(--max-width)) / 2)) 80px;
    animation: fadeIn 0.4s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .essay-nav { margin-bottom: 32px; }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    padding: 6px 12px 6px 8px;
    border-radius: 8px;
    transition: all var(--transition);
  }
  .back-link:hover { color: var(--text-primary); background: var(--bg-secondary); }

  .essay-header {
    margin-bottom: 48px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--border);
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .course-badge {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 7px;
  }

  .category-tag {
    font-size: 0.75rem;
    color: var(--text-muted);
    background: var(--bg-secondary);
    padding: 4px 10px;
    border-radius: 7px;
    font-weight: 500;
  }

  .status-tag {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 7px;
  }

  .tag-done {
    background: color-mix(in srgb, #10b981 12%, transparent);
    color: #10b981;
  }

  .tag-draft {
    background: var(--bg-secondary);
    color: var(--text-muted);
  }

  .essay-title {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 4vw, 2.4rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.03em;
    margin-bottom: 8px;
  }

  .course-name-full {
    font-size: 0.95rem;
    color: var(--text-muted);
    font-weight: 500;
    margin-bottom: 12px;
  }

  .essay-desc {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.65;
    max-width: 680px;
    margin-bottom: 28px;
  }

  .outcome-box {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    padding: 16px 20px;
    margin-bottom: 20px;
    max-width: 720px;
  }

  .outcome-header {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .outcome-text {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  .essay-date {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
    display: block;
  }

  /* Essay body typography */
  .essay-body {
    font-size: 1.05rem;
    line-height: 1.85;
    max-width: 720px;
  }

  .essay-body :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    margin: 40px 0 16px;
    letter-spacing: -0.02em;
  }

  .essay-body :global(h3) {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    margin: 32px 0 12px;
  }

  .essay-body :global(p) { margin-bottom: 20px; }

  .essay-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 4px 0 4px 20px;
    margin: 24px 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .essay-body :global(ul),
  .essay-body :global(ol) {
    margin: 16px 0;
    padding-left: 24px;
  }

  .essay-body :global(li) { margin-bottom: 8px; }

  .essay-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .essay-body :global(strong) { font-weight: 700; }

  .essay-body :global(em) { color: var(--text-secondary); }

  .essay-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 40px 0;
  }

  .essay-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
    font-size: 0.92rem;
  }

  .essay-body :global(th) {
    text-align: left;
    padding: 10px 14px;
    background: var(--bg-secondary);
    border-bottom: 2px solid var(--border);
    font-weight: 600;
  }

  .essay-body :global(td) {
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
  }

  @media (max-width: 640px) {
    .essay-body { font-size: 1rem; }
  }
</style>
