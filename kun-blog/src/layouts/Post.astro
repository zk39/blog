---
import Base from './Base.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: Date;
    tags: string[];
  };
}

const { frontmatter } = Astro.props;
const dateStr = new Date(frontmatter.date).toLocaleDateString('zh-CN', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---
<Base title={frontmatter.title} description={frontmatter.description}>
  <article class="article-view">
    <a href="/" class="article-back">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      返回文章列表
    </a>
    <div class="article-header">
      <h1>{frontmatter.title}</h1>
      <div class="article-meta">
        <time>{dateStr}</time>
        <div class="post-tags">
          {frontmatter.tags.map((tag: string) => (
            <span class="post-tag">{tag}</span>
          ))}
        </div>
      </div>
    </div>
    <div class="article-body">
      <slot />
    </div>
  </article>
</Base>

<style>
  .article-view {
    padding: 48px max(24px, calc((100vw - var(--max-width)) / 2)) 80px;
    animation: fadeIn 0.4s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .article-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 32px;
    padding: 6px 12px 6px 8px;
    border-radius: 8px;
    transition: all var(--transition);
  }

  .article-back:hover {
    color: var(--text-primary);
    background: var(--bg-secondary);
  }

  .article-header {
    margin-bottom: 40px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }

  .article-header h1 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.03em;
    margin-bottom: 12px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    color: var(--text-muted);
    font-size: 0.88rem;
  }

  .article-meta time {
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .post-tags { display: flex; gap: 6px; }

  .post-tag {
    font-size: 0.72rem;
    padding: 2px 10px;
    border-radius: 12px;
    background: var(--tag-bg);
    color: var(--tag-text);
    font-weight: 500;
  }

  .article-body {
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .article-body :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    margin: 40px 0 16px;
    letter-spacing: -0.02em;
  }

  .article-body :global(p) { margin-bottom: 20px; }

  .article-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--bg-secondary);
    padding: 2px 7px;
    border-radius: 5px;
    color: var(--accent);
  }

  .article-body :global(pre) {
    background: #1E1E22;
    border: 1px solid #2A2A2E;
    border-radius: var(--radius);
    padding: 20px 24px;
    overflow-x: auto;
    margin: 24px 0;
    font-size: 0.88rem;
    line-height: 1.65;
  }

  .article-body :global(pre code) {
    background: none;
    padding: 0;
    color: #EDEDEC;
  }

  .article-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 4px 0 4px 20px;
    margin: 24px 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 16px 0;
    padding-left: 24px;
  }

  .article-body :global(li) { margin-bottom: 8px; }

  .article-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .article-body :global(img) {
    max-width: 100%;
    border-radius: var(--radius);
    margin: 24px 0;
  }
</style>