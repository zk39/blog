---
const year = new Date().getFullYear();
---
<footer>
  <span>© {year} Kun Zhang</span>
  <div class="footer-links">
    <a href="https://github.com/zk39" target="_blank">GitHub</a>
    <span class="wechat-wrap">
      <span class="lang-zh">微信</span>
      <span class="lang-en">WeChat</span>
      <span class="wechat-id">zhangkun39</span>
    </span>
    <a href="/rss.xml">RSS</a>
  </div>
</footer>

<style>
  footer {
    padding: 32px max(24px, calc((100vw - var(--max-width)) / 2));
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--text-muted);
    font-size: 0.82rem;
  }

  .footer-links {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .footer-links a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer-links a:hover { color: var(--accent); }

  .wechat-wrap {
    display: flex;
    align-items: center;
    gap: 5px;
    color: var(--text-secondary);
  }

  .wechat-id {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    background: var(--bg-secondary);
    padding: 1px 7px;
    border-radius: 5px;
    color: var(--text-primary);
    user-select: all;
    cursor: text;
  }

  @media (max-width: 640px) {
    footer {
      flex-direction: column;
      gap: 12px;
      text-align: center;
    }
  }
</style>
